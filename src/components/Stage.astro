---
interface Props {
  id: string;
  num: string;
  title: string;
  question: string;
}
const { id, num, title, question } = Astro.props;
---

<section id={id} class="stage">
  <header class="stage-header">
    <span class="stage-num">stage {num}</span>
    <h2 class="stage-title">{title}</h2>
    <p class="stage-question">{question}</p>
  </header>

  <div class="stage-body">
    <slot />
  </div>
</section>

<style>
  .stage {
    margin: 6rem 0;
    scroll-margin-top: 6rem;
  }

  .stage-header {
    margin-bottom: 2.25rem;
  }

  .stage-num {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .stage-title {
    margin: 0.4rem 0 0;
    font-family: var(--font-serif);
    font-size: 2.4rem;
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.01em;
  }

  .stage-question {
    margin: 0.9rem 0 0;
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-style: italic;
    color: var(--color-ink-soft);
    max-width: 38rem;
  }

  .stage-body :global(p) {
    margin: 0 0 1.1rem;
    line-height: 1.7;
  }

  .stage-body :global(p.lead) {
    font-size: 1.1rem;
    color: var(--color-ink);
  }

  .stage-body :global(.incident) {
    margin: 1.75rem 0;
    padding: 1.25rem 1.4rem;
    border-left: 2px solid var(--color-accent);
    background: rgba(179, 54, 28, 0.035);
  }

  .stage-body :global(.incident-tag) {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .stage-body :global(.incident-headline) {
    margin: 0.4rem 0 0.7rem;
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 1.2rem;
    line-height: 1.3;
  }

  .stage-body :global(.defenses) {
    margin: 2rem 0 0;
    padding: 0;
    list-style: none;
  }

  .stage-body :global(.defenses li) {
    padding: 0.95rem 0;
    border-top: 1px solid var(--color-rule);
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 1.25rem;
  }

  .stage-body :global(.defenses li:last-child) {
    border-bottom: 1px solid var(--color-rule);
  }

  .stage-body :global(.defenses .defense-name) {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-ink);
    align-self: start;
  }

  .stage-body :global(.defenses .defense-desc) {
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-ink-soft);
  }

  @media (max-width: 640px) {
    .stage-title {
      font-size: 1.9rem;
    }
    .stage-body :global(.defenses li) {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }
  }
</style>
